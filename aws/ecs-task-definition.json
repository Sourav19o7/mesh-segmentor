{
  "family": "mesh-segmentor-inference",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/mesh-segmentor-task-role",
  "cpu": "4096",
  "memory": "16384",
  "containerDefinitions": [
    {
      "name": "mesh-segmentor-inference",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/mesh-segmentor:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "HOST", "value": "0.0.0.0"},
        {"name": "PORT", "value": "8000"},
        {"name": "LOG_LEVEL", "value": "INFO"},
        {"name": "LOG_FORMAT", "value": "json"},
        {"name": "USE_S3", "value": "true"},
        {"name": "S3_BUCKET", "value": "mesh-segmentor"},
        {"name": "PRELOAD_MODEL", "value": "true"},
        {"name": "MAX_CONCURRENT_JOBS", "value": "4"},
        {"name": "JOB_TIMEOUT", "value": "300"},
        {"name": "AWS_DEFAULT_REGION", "value": "us-east-1"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mesh-segmentor",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "inference"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/api/v1/live || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 120
      },
      "resourceRequirements": [
        {
          "type": "GPU",
          "value": "1"
        }
      ],
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "tmp-volume",
          "containerPath": "/tmp/mesh-segmentor",
          "readOnly": false
        }
      ]
    }
  ],
  "volumes": [
    {
      "name": "tmp-volume",
      "host": {
        "sourcePath": "/var/mesh-segmentor-tmp"
      }
    }
  ],
  "placementConstraints": [
    {
      "type": "memberOf",
      "expression": "attribute:ecs.instance-type =~ g5.*"
    }
  ],
  "tags": [
    {"key": "Project", "value": "mesh-segmentor"},
    {"key": "Environment", "value": "production"}
  ]
}
